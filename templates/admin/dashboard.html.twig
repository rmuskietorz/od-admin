{% extends 'base.html.twig' %}

{% block title %}Dashboard · od-admin{% endblock %}

{% block body %}
    <div class="page-head reveal">
        <div class="eyebrow">Open Design · Laufzeit</div>
        <h1>Dashboard</h1>
        <p class="sub">Steuerung des Open-Design-Containers und der gebündelten Claude CLI.</p>
    </div>

    <div class="card reveal" style="animation-delay:.06s">
        <div class="card-title">Container-Status</div>
        <div class="stat-grid">
            <div class="stat">
                <div class="k">Container</div>
                <div class="v mono">{{ status.name }}</div>
            </div>
            <div class="stat">
                <div class="k">Image</div>
                <div class="v mono">{{ status.image|default('–') }}</div>
            </div>
            <div class="stat">
                <div class="k">State</div>
                <div class="v">
                    {% if status.running %}
                        <span class="badge ok">running</span>
                    {% else %}
                        <span class="badge err">stopped</span>
                    {% endif %}
                    <span class="badge {{ status.health == 'healthy' ? 'ok' : (status.health == 'unhealthy' ? 'err' : 'warn') }}">
                        {{ status.health }}
                    </span>
                </div>
            </div>
            <div class="stat">
                <div class="k">Started</div>
                <div class="v mono">{{ status.started ?? '–' }}</div>
            </div>
        </div>

        <div class="btn-row" style="margin-top: 22px;">
            <button id="btn-status">↻ Aktualisieren</button>
            <button id="btn-restart" class="secondary">Restart</button>
            <button id="btn-update" class="secondary">Update (Pull + Up)</button>
            <button id="btn-logs" class="ghost">Logs anzeigen</button>
        </div>
        <pre id="action-out" style="margin-top: 16px; display: none;"></pre>
    </div>

    <div class="card reveal" style="animation-delay:.09s">
        <div class="card-title">Open-Design-Updates</div>
        {% if update_history is empty %}
            <p class="muted" style="margin-top:0;">Noch kein Update erfasst — der erste Eintrag entsteht beim nächsten Image-Wechsel (Watchtower prüft alle 6 h automatisch).</p>
        {% else %}
            <div class="stat-grid" style="margin-bottom:18px;">
                <div class="stat">
                    <div class="k">Zuletzt aktualisiert</div>
                    <div class="v">{{ update_history.0.at ? update_history.0.at|date('d.m.Y H:i') : '–' }}</div>
                </div>
                <div class="stat">
                    <div class="k">Aktuelles Image</div>
                    <div class="v mono" style="font-size:12px;">{{ update_history.0.digest|replace({'sha256:': ''})|slice(0, 12) }}</div>
                </div>
            </div>
            <div class="table-wrap">
                <table class="data">
                    <thead><tr><th>Zeitpunkt</th><th>Image</th><th>Digest</th></tr></thead>
                    <tbody>
                    {% for e in update_history %}
                        <tr>
                            <td class="text-mono" style="white-space: nowrap;">{{ e.at ? e.at|date('d.m.Y H:i') : '–' }}</td>
                            <td class="text-mono" style="font-size:12px;">{{ e.image|default('–') }}</td>
                            <td class="text-mono" style="font-size:12px;">{{ e.digest|replace({'sha256:': ''})|slice(0, 12) }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <p class="muted" style="font-size:12px; margin-top:12px;">
                Auto-Update via Watchtower (alle 6 h) · sofort: „Update (Pull + Up)" oben.
            </p>
        {% endif %}
    </div>

    <div class="card reveal" style="animation-delay:.12s">
        <div class="card-title">Claude CLI</div>
        <div id="claude-status" class="muted">Lade…</div>
        <div class="btn-row" style="margin-top: 18px;">
            <a href="{{ path('app_claude_login') }}" class="btn">Login öffnen</a>
            <button id="btn-claude-test" class="secondary">Test-Prompt</button>
            <button id="btn-claude-logout" class="danger">Logout (Credentials löschen)</button>
        </div>
        <pre id="claude-out" style="margin-top: 16px; display: none;"></pre>
    </div>

    <div class="card reveal" style="animation-delay:.15s">
        <div class="card-title">Sicherheit · 2FA</div>
        {% if two_factor_enabled %}
            <div class="stat-grid" style="margin-bottom: 16px;">
                <div class="stat">
                    <div class="k">Zwei-Faktor</div>
                    <div class="v"><span class="badge ok">aktiv</span></div>
                </div>
            </div>
            <form method="post" action="{{ path('app_2fa_disable') }}" class="btn-row"
                  onsubmit="return confirm('2FA wirklich deaktivieren?');">
                <input type="text" name="code" class="form-input" inputmode="numeric"
                       placeholder="Aktueller 6-stelliger Code" style="max-width: 240px;">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('2fa_disable') }}">
                <button type="submit" class="danger">2FA deaktivieren</button>
            </form>
        {% else %}
            <p class="muted" style="margin-top: 0;">
                Zweiter Faktor (TOTP) fürs Login — empfohlen, da hinter dem Login die
                Server-Steuerung liegt.
            </p>
            <div class="btn-row">
                <a href="{{ path('app_2fa_setup') }}" class="btn">2FA aktivieren</a>
                <span class="badge err">inaktiv</span>
            </div>
        {% endif %}
    </div>

    <div class="card reveal" id="logs-card" style="display: none;">
        <div class="card-title">Logs · live</div>
        <pre id="logs-pre"></pre>
        <div class="btn-row" style="margin-top: 14px;">
            <button id="btn-logs-close" class="ghost">Schließen</button>
        </div>
    </div>

    {% block javascripts %}
    <script>
        const actionOut = document.getElementById('action-out');
        const claudeOut = document.getElementById('claude-out');

        function showJson(el, value) {
            el.style.display = '';
            el.textContent = JSON.stringify(value, null, 2);
        }

        // Prozess-Ergebnis lesbar darstellen (statt rohem JSON).
        function showProc(el, j) {
            el.style.display = '';
            let t = (j.ok === false ? '✗ Fehler' : '✓ OK');
            for (const k of ['stdout', 'stderr', 'output', 'error']) {
                if (j[k]) t += '\n\n── ' + k + ' ──\n' + j[k];
            }
            el.textContent = t.trim();
        }

        async function call(url, method = 'POST') {
            actionOut.style.display = '';
            actionOut.textContent = 'läuft …';
            const r = await fetch(url, { method, headers: { 'Accept': 'application/json' } });
            const j = await r.json();
            showProc(actionOut, j);
            return j;
        }

        document.getElementById('btn-status').onclick = () => location.reload();
        document.getElementById('btn-restart').onclick = () => call('{{ path('app_restart') }}');
        document.getElementById('btn-update').onclick = () => {
            if (!confirm('Neuestes Image ziehen und Container neu erzeugen?')) return;
            const btn = document.getElementById('btn-update');
            actionOut.style.display = '';
            actionOut.textContent = '';
            btn.disabled = true;
            let done = false;
            // Live-Stream (SSE): Pull + Recreate zeilenweise sichtbar.
            const es = new EventSource('{{ path('app_update_stream') }}');
            es.onmessage = (e) => {
                if (e.data === '[DONE]') {
                    done = true; es.close(); btn.disabled = false;
                    actionOut.textContent += '\n→ Klick „Aktualisieren" fuer den neuen Status.';
                    refreshClaudeStatus();
                    return;
                }
                actionOut.textContent += e.data.replace(/\\n/g, '\n') + '\n';
                actionOut.scrollTop = actionOut.scrollHeight;
            };
            es.onerror = () => {
                if (done) return;
                es.close(); btn.disabled = false;
                actionOut.textContent += '\n[Verbindung beendet]';
            };
        };

        function badge(cls, text) {
            const span = document.createElement('span');
            span.className = 'badge ' + cls;
            span.textContent = text;
            return span;
        }

        async function refreshClaudeStatus() {
            const cs = document.getElementById('claude-status');
            cs.textContent = '';
            cs.className = '';
            const r = await fetch('{{ path('app_claude_status') }}');
            const j = await r.json();

            const grid = document.createElement('div');
            grid.className = 'stat-grid';

            const c1 = document.createElement('div');
            c1.className = 'stat';
            const k1 = document.createElement('div'); k1.className = 'k'; k1.textContent = 'CLI Version';
            const v1 = document.createElement('div'); v1.className = 'v mono';
            v1.textContent = j.cli_version || 'unbekannt';
            c1.append(k1, v1);

            const c2 = document.createElement('div');
            c2.className = 'stat';
            const k2 = document.createElement('div'); k2.className = 'k'; k2.textContent = 'Credentials';
            const v2 = document.createElement('div'); v2.className = 'v';
            v2.append(j.has_credentials ? badge('ok', 'vorhanden') : badge('err', 'fehlt'));
            c2.append(k2, v2);

            grid.append(c1, c2);
            cs.append(grid);
        }
        refreshClaudeStatus();

        document.getElementById('btn-claude-test').onclick = async () => {
            claudeOut.style.display = '';
            claudeOut.textContent = 'läuft …';
            const r = await fetch('{{ path('app_claude_test') }}', { method: 'POST' });
            showJson(claudeOut, await r.json());
        };
        document.getElementById('btn-claude-logout').onclick = async () => {
            if (!confirm('Credentials wirklich löschen?')) return;
            await fetch('{{ path('app_claude_logout') }}', { method: 'POST' });
            refreshClaudeStatus();
        };

        // ── Logs SSE ────────────────────────────────────────────────────────
        let logSource = null;
        document.getElementById('btn-logs').onclick = () => {
            const card = document.getElementById('logs-card');
            const pre = document.getElementById('logs-pre');
            card.style.display = '';
            pre.textContent = '';
            logSource = new EventSource('{{ path('app_logs') }}');
            logSource.onmessage = (e) => {
                pre.append(e.data + '\n');
                pre.scrollTop = pre.scrollHeight;
            };
        };
        document.getElementById('btn-logs-close').onclick = () => {
            if (logSource) { logSource.close(); logSource = null; }
            document.getElementById('logs-card').style.display = 'none';
        };
    </script>
    {% endblock %}
{% endblock %}
