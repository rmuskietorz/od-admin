{% extends 'base.html.twig' %}

{% block title %}Audit-Log · od-admin{% endblock %}

{% block body %}
    <div class="page-head reveal">
        <div class="eyebrow">Sicherheit · Zugriffe</div>
        <h1>Audit-Log</h1>
        <p class="sub">
            Letzte 100 Login-Versuche. Bei 5 Fehlversuchen pro Minute (IP + Username)
            sperrt Symfony automatisch via <span class="text-mono">login_throttling</span>.
        </p>
    </div>

    <div class="card reveal" style="animation-delay:.06s">
        <div class="card-title">Login-Versuche</div>

        {% if attempts is empty %}
            <div class="empty-state">Noch keine Einträge.</div>
        {% else %}
            <div class="table-wrap">
                <table class="data">
                    <thead>
                        <tr>
                            <th>Zeit</th>
                            <th>User</th>
                            <th>IP</th>
                            <th>Status</th>
                            <th>Grund</th>
                            <th>User-Agent</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for a in attempts %}
                            <tr>
                                <td class="text-mono" style="white-space: nowrap;">{{ a.createdAt|date('Y-m-d H:i:s') }}</td>
                                <td><code>{{ a.username }}</code></td>
                                <td><code>{{ a.ip }}</code></td>
                                <td>
                                    {% if a.success %}
                                        <span class="badge ok">ok</span>
                                    {% else %}
                                        <span class="badge err">fail</span>
                                    {% endif %}
                                </td>
                                <td class="muted" style="font-size: 12px;">{{ a.reason ?? '–' }}</td>
                                <td class="muted" style="font-size: 11px; max-width: 300px; overflow: hidden;
                                           text-overflow: ellipsis; white-space: nowrap;"
                                    title="{{ a.userAgent }}">
                                    {{ a.userAgent|default('–')|slice(0, 60) }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    <div class="btn-row">
        <a href="{{ path('app_dashboard') }}" class="btn ghost">← Zurück zum Dashboard</a>
    </div>
{% endblock %}
