# Symfony Default-Werte. Lokale Overrides in .env.local (gitignored).

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=changeme-via-env-local

# Doctrine: SQLite reicht fuer User-DB (Single-Tenant Admin-Tool).
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data/app.db"

# Open Design (interner Docker-Netz-Hostname)
OD_CONTAINER_NAME=open-design-claude
OD_UPSTREAM_URL=http://open-design-claude:7456
OD_COMPOSE_FILE=/host/open-design/docker-compose.claude-cli.server.yml

# ttyd Sidecar fuer Claude-Login Terminal
TTYD_UPSTREAM_URL=http://ttyd:7681
TTYD_SHARED_TOKEN=changeme-via-env-local

# Docker-Daemon Zugriff
# Default: gemounteter Socket. Spaeter ueber socket-proxy: tcp://docker-socket-proxy:2375
DOCKER_HOST=unix:///var/run/docker.sock

# Port-Binding des Admin-Panels (Host-seitig).
# 8082 ist auf vielen Hosts belegt -> 8086 als robusterer Default. Die
# Server-Einrichtung (helper.sh Punkt 86) prueft den Port und waehlt bei
# Konflikt automatisch einen freien.
OD_ADMIN_PORT=8086

# Compose-Restart-Policy. Lokal absichtlich NICHT gesetzt -> Fallback "no"
# (kein Auto-Restart beim Booten / Docker-Neustart). Auf dem Prod-Server
# auf "unless-stopped" setzen, damit der Stack einen Reboot ueberlebt:
#   OD_ADMIN_RESTART=unless-stopped
# OD_ADMIN_RESTART=unless-stopped

# Session-Cookie MUSS path=/ haben: der nginx auth_request auf /_auth_check
# laeuft beim Aufruf von / (OD-Reverse-Proxy), und nginx reicht nur Cookies
# weiter, deren Pfad zu / passt. Mit /admin wuerde das Session-Cookie fuer /
# nie gesendet -> Auth-Gate immer 401 -> OD fuer niemanden erreichbar.
# Kollision mit OD-Cookies droht nicht (OD nutzt andere Namen, nicht PHPSESSID).
COOKIE_PATH=/
