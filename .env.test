APP_ENV=test
APP_SECRET=test-secret-do-not-use-in-prod
APP_DEBUG=1

# File-DB (kein :memory:): WebTestCase rebootet den Kernel zwischen Requests,
# eine in-memory-DB waere danach leer. Test-Isolation kommt stattdessen aus
# dropDatabase()+createSchema() pro Test (siehe createTestUser/setUp).
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data/test.db"

OD_CONTAINER_NAME=open-design-claude
OD_UPSTREAM_URL=http://localhost:7456
OD_COMPOSE_FILE=/tmp/dummy-compose.yml
TTYD_UPSTREAM_URL=http://localhost:7681
TTYD_SHARED_TOKEN=test-token
DOCKER_HOST=unix:///var/run/docker.sock
COOKIE_PATH=/
